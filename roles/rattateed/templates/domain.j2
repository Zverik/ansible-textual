{% if rattateed_cert.stat.exists %}
<VirtualHost *:443>
{% else %}
<VirtualHost *:80>
{% endif %}
  ServerName {{ domain }}
  DocumentRoot {{ sites }}/osmz.ru/rattateed/web

  CustomLog /var/log/apache2/{{ domain }}/access_log combined
  ErrorLog /var/log/apache2/{{ domain }}/error_log

{% if rattateed_cert.stat.exists %}
  SSLEngine on
  SSLCertificateFile "{{ cert_path.rattateed }}/fullchain.pem"
  SSLCertificateKeyFile "{{ cert_path.rattateed }}/privkey.pem"
{% endif %}

  <Directory {{ sites }}/osmz.ru/rattateed>
    Options FollowSymLinks Includes MultiViews
    AllowOverride All
  </Directory>
</VirtualHost>

{% if rattateed_cert.stat.exists %}
<VirtualHost *:80>
  ServerName {{ domain }}
  ServerAlias www.{{ domain }}
	Redirect permanent / https://{{ domain }}/
</VirtualHost>
{% endif %}
