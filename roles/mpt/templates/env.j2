# Database
DB_HOST=localhost
DB_USER={{ mpt_mysql_user }}
DB_PASSWORD={{ mpt_mysql_password }}
DB_NAME={{ mpt_mysql_db }}

# OpenStreetMap OAuth2
OSM_CLIENT_ID={{ mpt_osm_client }}
OSM_CLIENT_SECRET={{ mpt_osm_secret }}

# Session security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET={{ mpt_secret }}

# Base URL for OAuth callback (no trailing slash)
BASE_URL=https://{{ domain }}
PORT={{ mpt_port }}
